# Copy to .env and adjust as needed
# cp .env.example .env

# Local model directory (must contain config.json + weights)
MODEL_PATH=/mnt/cache/tonghao2/data/models/Qwen/Qwen2.5-Coder-14B-Instruct

# Optional: pick a preset from config/models.yaml instead of manual MODEL_PATH
# MODEL_KEY=qwen2.5-coder-14b

# Server
HOST=0.0.0.0
PORT=8721
SERVED_MODEL_NAME=qwen2.5-coder-14b

# vLLM tuning
MAX_MODEL_LEN=32768
GPU_MEM_UTIL=0.90
# TENSOR_PARALLEL_SIZE=1
# VLLM_EXTRA_ARGS="--reasoning-parser qwen3 --max-num-seqs 256"

# Example: Qwen3.5-122B-A10B-FP8 on 8 GPUs (official config)
# MODEL_KEY=qwen3.5-122b-a10b-fp8
# TENSOR_PARALLEL_SIZE=8
# MAX_MODEL_LEN=262144
# VLLM_EXTRA_ARGS="--reasoning-parser qwen3 --max-num-seqs 256"

# Leave empty to disable API key auth
API_KEY=

# Hugging Face cache (for download script and remote model ids)
HF_HOME=/mnt/cache/tonghao2/data/cache
HF_TOKEN=
