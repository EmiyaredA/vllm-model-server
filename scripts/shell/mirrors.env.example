# Copy to mirrors.env and adjust if needed:
#   cp scripts/shell/mirrors.env.example scripts/shell/mirrors.env
#
# Used by scripts/shell/install.sh

# PyPI mirror (recommended in CN / restricted containers)
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/

# pip trusted-host (derived from index URL if omitted)
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# Conda channel mirror (optional; uncomment to use Tsinghua conda-forge)
# CONDA_FORGE_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/anaconda/cloud/conda-forge/

# Hugging Face endpoint for model downloads (scripts/download.py)
HF_ENDPOINT=https://hf-mirror.com

# hf-mirror 不支持 XET 存储，大模型下载需禁用（否则 cas-server.xethub.hf.co 401）
HF_HUB_DISABLE_XET=1

# 大模型并发过高易触发 429，默认单线程
HF_DOWNLOAD_MAX_WORKERS=1

# 1=下载时忽略系统代理（推荐，走 hf-mirror）；0=使用系统代理（需 pip install httpx[socks]）
HF_UNSET_PROXY=1

# Conda env name
CONDA_ENV_NAME=vllm-model-server
